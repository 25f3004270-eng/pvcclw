# Environment variables for PVC Calculator

# Flask secret key (REQUIRED in production - generate a random string)
SECRET_KEY=your-secret-key-here

# Admin default password (used by flask init-db)
ADMIN_PASSWORD=admin123

# Database URL
# Local MySQL: mysql+pymysql://root:password@localhost/pvc_db
# Render: will be auto-set by DATABASE_URL env var
DATABASE_URL=mysql+pymysql://root:@localhost/pvc_db

# Flask debug mode (true or false)
FLASK_DEBUG=false

# Port (default 5000)
PORT=5000
